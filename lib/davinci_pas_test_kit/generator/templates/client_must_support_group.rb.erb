require_relative '../../<%= ig_version %>/workflows/pas_client_<%= operation %>_gather_must_support_test'
<%- if operation == 'submit' -%>
require_relative '../../<%= ig_version %>/must_support/pas_client_must_support_request_profiles_test'
<%- end -%>
<%- profile_test_files.each do |file_name| -%>
require_relative '<%= file_name %>'
<%- end -%>

module DaVinciPASTestKit
  module <%= module_name %>
    class <%= class_name %> < Inferno::TestGroup
      id :<%= group_id %>
      title '<%= title %>'
      description %(
        <%=description.gsub("\n", "\n" + " "*8) %>
      )
      run_as_group
      
      test from: :pas_client_<%= ig_version_for_id %>_<%= operation %>_gather_must_support
      <%- if operation == 'submit' -%>
      test from: :pas_client_<%= ig_version_for_id %>_must_support_request_profiles
      <%- end -%>
      <%- profile_test_ids.each do |id| -%>
      test from: :<%= id %>
      <%- end -%>
    end
  end
end
