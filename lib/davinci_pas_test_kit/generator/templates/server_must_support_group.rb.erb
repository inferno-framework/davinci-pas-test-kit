require_relative '../../server_request_bundle_validation_test'
require_relative '../../claim_submit_operation_test'
require_relative '../../server_response_bundle_validation_test'
require_relative '../../claim_inquire_operation_test'
require_relative '../../<%= ig_version %>/must_support/pas_server_must_support_request_profiles_test'
<%- profile_test_files('submit', 'request').each do |file_name| -%>
require_relative '<%= file_name %>'
<%- end -%>
<%- profile_test_files('submit', 'response').each do |file_name| -%>
require_relative '<%= file_name %>'
<%- end -%>
<%- profile_test_files('inquire', 'request').each do |file_name| -%>
require_relative '<%= file_name %>'
<%- end -%>
<%- profile_test_files('inquire', 'response').each do |file_name| -%>
require_relative '<%= file_name %>'
<%- end -%>

module DaVinciPASTestKit
  module <%= module_name %>
    class <%= class_name %> < Inferno::TestGroup
      id :<%= group_id %>
      title '<%= title %>'
      description %(
        <%=description.gsub("\n", "\n" + " "*8) %>
      )

      <%- if verifies_requirements -%>
      verifies_requirements <%= verifies_requirements.map { |r| "'#{r}'" }.join(', ') %>
      <%- end -%>

      <%- ['submit', 'inquire'].each do |operation| %>
      group do
        title '$<%= operation %> Element Support'
        description %(
          <%= subgroup_description(operation).gsub("\n", "\n" + " "*10) %>
        )
        run_as_group

        group do
          title 'Submission of claims to the $<%= operation %> operation for must support validation'

          test from: :pas_server_request_bundle_validation_test do
            id :pas_server_<%= ig_version_for_id %>_<%= operation %>_request_bundle_validation_test_must_support
            title '[USER INPUT VALIDATION] Provided $<%= operation %> Request Bundle is conformant'
            description %(
              <%= Descriptions.bundle_validation_test_description(operation, 'request').gsub("\n", "\n" + " "*12) %>
            )
            config(
              inputs: {
                bundle_payload: {
                  name: :must_support_pa_<%= operation %>_request_payload ,
                  title: 'Additional $<%= operation %> Request Payloads',
                  description: 'Insert an additional request bundle or a list of bundles (e.g. [bundle_1, bundle_2])'
                }
              },
              options: {
                operation: '<%= operation %>',
                use_case: 'must_support',
                ig_version: '<%= ig_version %>'
              }
            )
          end
          test from: :pas_claim_<%= operation %>_operation_test do
            id :pas_<%= ig_version_for_id %>_claim_<%= operation %>_operation_test_must_support
            config(
              inputs: {
                pa_<%= operation %>_request_payload: {
                  name: :must_support_pa_<%= operation %>_request_payload,
                  title: 'Additional $<%= operation %> Request Payloads',
                  description: 'Insert an additional request bundle or a list of bundles (e.g. [bundle_1, bundle_2])'
                }
              },
              options: {
                use_case: 'must_support',
                ig_version: '<%= ig_version %>'
              }
            )
          end
          test from: :pas_server_response_bundle_validation_test do
            id :pas_server_<%= ig_version_for_id %>_<%= operation %>_response_bundle_validation_test_must_support
            title 'Server $<%= operation %> Response Bundle is conformant'
            description %(
              <%= Descriptions.bundle_validation_test_description(operation, 'response').gsub("\n", "\n" + " "*14) %>
            )
            config(
              options: {
                use_case: 'must_support',
                operation: '<%= operation %>',
                ig_version: '<%= ig_version %>'
              }
            )
          end
        end

        group do
          title '[USER INPUT VALIDATION] $<%= operation %> Request Must Support'
          <%- if verifies_must_support_requirements(operation, 'request').present? -%>
          verifies_requirements <%= verifies_must_support_requirements(operation, 'request').map { |r| "'#{r}'" }.join(', ') %>
          <%- end -%>

          <%- if operation == 'submit' -%>
          test from: :pas_server_<%= ig_version_for_id %>_must_support_request_profiles
          <%- end -%>
          <%- profile_test_ids(operation, 'request').each do |id| -%>
          test from: :<%= id %>
          <%- end -%>
        end

        group do
          title '$<%= operation %> Response Must Support'
          <%- profile_test_ids(operation, 'response').each do |id| -%>
          test from: :<%= id %>
          <%- end -%>
        end
      end<%end%>
    end
  end
end
